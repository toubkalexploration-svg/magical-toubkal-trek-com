# Serve the custom Next.js 404 page
ErrorDocument 404 /404.html

# Force HTTPS and the canonical www host (matches metadataBase / canonical tags)
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http -> https
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} =http
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # non-www -> www
  RewriteCond %{HTTP_HOST} ^magical-toubkal-trek\.com$ [NC]
  RewriteRule ^ https://www.magical-toubkal-trek.com%{REQUEST_URI} [L,R=301]
</IfModule>

# Gzip / Brotli compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

# Cache static assets aggressively; keep HTML fresh
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Immutable caching for Next.js hashed build assets
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|woff2|jpg|jpeg|png|webp|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
